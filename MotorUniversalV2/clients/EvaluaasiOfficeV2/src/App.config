<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <appSettings>
    <!-- URL base del backend MotorV2. Cambia a -dev para entorno DEV. -->
    <!-- DEV:  https://evaluaasi-motorv2-api-dev.purpleocean-384694c4.southcentralus.azurecontainerapps.io/api -->
    <!-- PROD: https://evaluaasi-motorv2-api.purpleocean-384694c4.southcentralus.azurecontainerapps.io/api -->
    <add key="MotorV2.BaseUrl" value="https://evaluaasi-motorv2-api.purpleocean-384694c4.southcentralus.azurecontainerapps.io/api" />
    <add key="MotorV2.TimeoutSeconds" value="60" />
    <add key="MotorV2.AppName" value="EvaluaasiOfficeV2" />
  </appSettings>
</configuration>
